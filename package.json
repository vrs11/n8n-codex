{
	"name": "n8n-nodes-openai-codex",
	"version": "0.1.0",
	"description": "n8n AI chat model node for Codex-style ChatGPT backend using manual auth values",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"openai",
		"codex",
		"ai"
	],
	"author": {
		"name": "vrs11",
		"email": "vrs11@example.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/<your-org>/n8n-nodes-openai-codex.git"
	},
	"scripts": {
